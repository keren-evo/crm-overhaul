{
  "project": "CRM Status Architecture Rebuild",
  "version": "2.0.0",
  "updated": "2026-07-02",
  "instructions": "Create at Project → Customize → Fields. Names must match CSV exactly.",
  "fields": [
    {
      "name": "Workstream",
      "type": "single_select",
      "options": ["Governance", "Definitions", "Baseline", "Architecture", "Build", "Remediation", "Dashboards", "Go-Live", "Training", "Growth"],
      "description": "Logical work area — replaces phase numbers"
    },
    {
      "name": "Decision Gate",
      "type": "single_select",
      "options": ["Yes", "No"],
      "description": "Yes when task is a formal sign-off or go/no-go gate"
    },
    {
      "name": "Blocker",
      "type": "single_select",
      "options": ["Yes", "No"],
      "description": "Yes for milestones and tasks that block downstream work"
    },
    {
      "name": "Requires Stakeholder Decision",
      "type": "single_select",
      "options": ["Yes", "No"],
      "description": "Yes when Joel, Angelo, or leadership must decide before proceeding"
    },
    {
      "name": "CRM Environment",
      "type": "single_select",
      "options": ["Discovery", "Staging", "Production"],
      "description": "Where this task is executed"
    },
    {
      "name": "Effort",
      "type": "single_select",
      "options": ["S", "M", "L"],
      "description": "S = hours, M = days, L = week+"
    },
    {
      "name": "Priority",
      "type": "single_select",
      "options": ["P0", "P1", "P2", "P3"],
      "description": "P0 = critical path, P3 = post-launch"
    },
    {
      "name": "Baseline / Target Metric",
      "type": "text",
      "description": "Measurable outcome e.g. ~1960 authorized → 1200-1300 census"
    }
  ],
  "bulk_defaults_by_section": {
    "Governance & Project Setup": { "Workstream": "Governance", "CRM Environment": "Discovery", "Priority": "P0" },
    "Business Definitions & Sign-Off": { "Workstream": "Definitions", "CRM Environment": "Discovery", "Priority": "P0", "Requires Stakeholder Decision": "Yes" },
    "Current State & Data Baseline": { "Workstream": "Baseline", "CRM Environment": "Discovery", "Priority": "P0" },
    "Target Architecture & Migration Design": { "Workstream": "Architecture", "CRM Environment": "Discovery", "Priority": "P0" },
    "CRM Build — Staging": { "Workstream": "Build", "CRM Environment": "Staging", "Priority": "P0" },
    "Data Remediation & QA": { "Workstream": "Remediation", "CRM Environment": "Staging", "Priority": "P0" },
    "Dashboards & User Acceptance": { "Workstream": "Dashboards", "CRM Environment": "Staging", "Priority": "P0" },
    "Production Go-Live": { "Workstream": "Go-Live", "CRM Environment": "Production", "Priority": "P0" },
    "Documentation, Training & NY Playbook": { "Workstream": "Training", "CRM Environment": "Discovery", "Priority": "P1" },
    "Growth Enablement": { "Workstream": "Growth", "CRM Environment": "Discovery", "Priority": "P2" }
  }
}
